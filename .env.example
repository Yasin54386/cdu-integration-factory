# Copy to .env and fill in real values:  cp .env.example .env
# .env is GITIGNORED — it holds credential VALUES and must NEVER be committed
# (THE WALL, spec §7). The CLI auto-loads it; real env vars / CI Actions
# Secrets take precedence, so CI is unaffected (it sets no .env).

# Oracle — Callista SIS dev (metadata host/port/sid live in connections.yaml)
ORACLE_DEV_USER="ORDS_PUBLIC_USER[SIS_OWNER]"
ORACLE_DEV_PASSWORD="your-callista-password"

# GitLab — MuleSoft repo push (mule-deliver), scope write_repository
MULE_REPO_TOKEN="glpat-..."

# GHE — factory branch/commit (skip if git already authenticates to GHE)
GHE_TOKEN="ghe_pat_..."

# SFTP — only if your intent names the sftp_dev connection
# SFTP_DEV_USER="..."
# SFTP_DEV_PRIVATE_KEY="..."
